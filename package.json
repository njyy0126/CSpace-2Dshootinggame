{
  "name": "browser-2d-pvp-shooter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"tsx watch src/server/index.ts\" \"vite\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "vite build && tsup src/server/index.ts --format esm --platform node --out-dir dist/server --clean",
    "build:client": "vite build",
    "build:server": "tsup src/server/index.ts --format esm --platform node --out-dir dist/server --clean",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:e2e": "npm run build && playwright test",
    "test:watch": "vitest"
  },
  "dependencies": {
    "express": "^5.2.1",
    "phaser": "^3.90.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "concurrently": "^10.0.3",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.2",
    "vitest": "^4.1.9"
  }
}
